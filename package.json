{
  "name": "walrus_notes",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "preview": "vite preview --host 0.0.0.0 --port $PORT",
    "start:dev": "tsx watch server/index.ts",
    "format": "prettier --write src/**/*.{ts,tsx,json,css}",
    "format:check": "prettier --check src/**/*.{ts,tsx,json,css}",
    "type-check": "tsc --noEmit",
    "build": "vite build && npm run build:server",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist-server/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:unused": "eslint . --report-unused-disable-directives --no-error-on-unmatched-pattern",
    "lint:styles": "stylelint \"src/styles/**/*.css\" \"src/app/styles/markdown.css\"",
    "check:raw-colors": "if grep -RInE \"#[0-9a-fA-F]{3,8}|rgba\\(\" src/features/graph src/app/styles/markdown.css src/widgets/ui/components/sidebar/Sidebar.tsx src/pages/main/ui/components/Tabs.tsx src/pages/main/ui/components/SortableTab.tsx src/app/providers/modal/Modal.tsx src/features/profile/ui/components/ProfileButton.tsx src/widgets/ui/components/fileTree/SearchInput.tsx src/widgets/ui/components/header/MobileMenu.tsx src/features/notes/ui/components/HelpSection.tsx; then echo 'Raw colors found in guarded zones'; exit 1; fi",
    "guardrails": "pnpm run lint:styles && pnpm run check:raw-colors"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@headlessui/react": "^2.2.8",
    "@reduxjs/toolkit": "^2.9.0",
    "@tailwindcss/vite": "^4.1.13",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "express": "4.18.2",
    "formik": "^2.4.6",
    "framer-motion": "^12.23.22",
    "i18next": "^25.5.3",
    "i18next-browser-languagedetector": "^8.2.0",
    "lucide-react": "^0.562.0",
    "prism-react-renderer": "^1.3.1",
    "prismjs": "^1.29.0",
    "react": "^19.1.1",
    "react-colorful": "^5.6.1",
    "react-dom": "^19.1.1",
    "react-i18next": "^16.0.0",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.9.3",
    "react-use-websocket": "^4.13.0",
    "reactflow": "^11.11.4",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.13",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.29",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@types/cors": "^2.8.19",
    "@types/express": "4.17.21",
    "@types/node": "^24.6.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@types/react-router-dom": "^5.3.3",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "@vitejs/plugin-react": "^5.0.3",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-boundaries": "^5.4.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-prettier": "^5.1.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-unicorn": "^63.0.0",
    "globals": "^16.5.0",
    "jiti": "^2.6.1",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "rollup-plugin-visualizer": "^7.0.0",
    "stylelint": "^16.24.0",
    "terser": "^5.46.0",
    "tsx": "^4.20.6",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.46.2",
    "vite": "^7.1.7",
    "vite-plugin-compression2": "^2.5.0"
  }
}
